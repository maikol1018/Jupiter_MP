# H5 本地开发：参照 BAZI，前端请求同源 /api，由 Taro devServer 代理到本机中转。
# 先启动本地中转：GEMINI_API_KEY=xxx npm run relay
# 中国区网络如需代理，在启动中转前设置 HTTPS_PROXY / HTTP_PROXY / ALL_PROXY。
JUPITER_API_BASE=

# 仅当 JUPITER_API_BASE 留空时，Taro devServer 才会代理 /api 和 /audio 到这里。
# 本地默认使用 Jupiter 中转服务；如需远端 VPS，可改成 https://api.jupiter-astro.top。
JUPITER_API_PROXY_TARGET=http://localhost:3000
JUPITER_AUTH_KEY=jupiter-2026
JUPITER_SHARE_URL=http://192.168.0.11:5173/
